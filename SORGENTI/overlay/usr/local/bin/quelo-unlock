      select_help)     echo "Number=choice | Q=back" ;;
      prompt)          echo "Choice: " ;;
      invalid)         echo "Invalid choice." ;;
      unknown)         echo "N/A" ;;
      op_win)          echo "Windows password" ;;
      op_linux)        echo "Linux password" ;;
      op_luks)         echo "Unlock LUKS" ;;
      op_bitlocker)    echo "Unlock BitLocker" ;;
      disc_header)     echo "********WARNING - EXPERIMENTAL*********" ;;
      disc_title)      echo "IMPORTANT — READ BEFORE CONTINUING" ;;
      disc_1)          echo "Original passwords CANNOT be recovered, only RESET." ;;
      disc_2)          echo "Encrypted disks (BitLocker, LUKS) must be UNLOCKED first." ;;
      disc_3)          echo "Windows: Microsoft / domain accounts cannot be reset here." ;;
      disc_4)          echo "Windows: EFS files may become unreadable after password reset." ;;
      disc_5)          echo "Changes WRITE to the disk — use at your own risk." ;;
      disc_6)          echo "LUKS/BitLocker: YOUR passphrase or recovery key required — NOT hacking/brute-force." ;;
      disc_confirm)    echo "I understand. Continue? [y/n]: " ;;
      danger_warn)     echo "WARNING: will modify accounts on %s" ;;
      danger_confirm1) echo "Continue? Account data will be changed. [y/n]: " ;;
      danger_confirm2) echo "Are you REALLY sure? [y/n]: " ;;
