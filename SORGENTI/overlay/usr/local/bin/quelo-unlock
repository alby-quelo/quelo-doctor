#!/bin/bash

export LC_ALL="${LC_ALL:-it_IT.UTF-8}"
export LANG="${LANG:-it_IT.UTF-8}"
export TERM="${TERM:-linux}"

Q_BIN="$(dirname "$(readlink -f "$0")")"
UNLOCK_DISCLAIMER_STAMP="/run/quelo-unlock-disclaimer-ok"

# shellcheck disable=SC1091
. "${Q_BIN}/quelo-console-quiet.sh"
quelo_console_quiet_on
# shellcheck disable=SC1091
. "${Q_BIN}/quelo-fs.sh"

C_GREEN_BOLD=$'\033[1;32m'
C_GREEN=$'\033[32m'
C_AMBER_BOLD=$'\033[1;33m'
C_AMBER=$'\033[33m'
C_RED=$'\033[1;31m'
C_RESET=$'\033[0m'

DISK_DEVS=()
DISK_SIZES=()
DISK_MODELS=()
DISK_VENDORS=()
DISK_TRANS=()
DISK_CHOICE=""

quelo_unlock_tty() {
  printf '%b' "$*" >/dev/tty 2>/dev/null || printf '%b' "$*"
}

quelo_unlock_ttyln() {
  quelo_unlock_tty "$*"
  quelo_unlock_tty $'\n'
}

quelo_unlock_ui_is_en() {
  [[ -f /etc/default/locale ]] && grep -qE '^LANG=en_' /etc/default/locale
}

quelo_unlock_t() {
